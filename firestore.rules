rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Public read-only reference data
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Approved places are public; only admins write directly.
    // Community contributions go through /submissions.
    match /places/{placeId} {
      allow read: if resource.data.status == "approved" || isAdmin();
      allow write: if isAdmin();
    }

    match /routes/{routeId} {
      allow read: if resource.data.status == "approved" || isAdmin();
      allow write: if isAdmin();
    }

    match /tripTemplates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users can read/update only their own profile.
    match /users/{userId} {
      allow read, update: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Submissions: any signed-in user can create. Only admins can list/read/update.
    match /submissions/{submissionId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == "pending";
      allow read, update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
