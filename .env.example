NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Anthropic Claude — https://console.anthropic.com/
# When set, the map generator enriches OSM places with descriptions, local
# tips, a walking route, and a budget itinerary using Claude Opus 4.7 with
# the web_search tool. Without this key the map still works using raw OSM data.
#
# Server-side only — do NOT prefix with NEXT_PUBLIC_ (would expose to browser).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7

# Unsplash — https://unsplash.com/oauth/applications
# Used server-side to fetch destination photos for the hero, gallery, and
# trip planner cards. Only the Access Key is needed — the Secret Key is for
# OAuth flows we don't use, so do NOT put it in this file.
#
# Server-side only — do NOT prefix with NEXT_PUBLIC_.
UNSPLASH_ACCESS_KEY=

# Pexels — https://www.pexels.com/api/
# Free CC0 stock video API. Fetches a looping travel clip for the landing-page
# hero background. (Unsplash doesn't have a video API, so we use Pexels for
# video and keep Unsplash for photos.) Free tier: 200 req/hour, 20K/month.
#
# Server-side only — do NOT prefix with NEXT_PUBLIC_.
PEXELS_API_KEY=

# OSRM — Open Source Routing Machine. Walking-route geometry that follows
# real streets. Defaults to the OSRM public demo server (free, no key, but
# fair-use only). For production traffic, host your own and set this URL.
# OSRM_BASE_URL=https://router.project-osrm.org
OSRM_BASE_URL=
